# VisionPower MCP Server - Environment Variables
# These variables configure only the upstream vision model.

# Protocol used by the provider's compatible API: openai or anthropic.
VISION_POWER_API_PROTOCOL=openai

# Vision model API endpoint. Example below is OpenAI-compatible.
VISION_POWER_API_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# API key for the vision model.
VISION_POWER_API_KEY=your_api_key_here

# Model name. Example below uses MiMo; replace it when using another provider.
VISION_POWER_MODEL=mimo-v2.5

# Request timeout in seconds.
VISION_POWER_TIMEOUT=120
