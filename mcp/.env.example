# MiMo Vision MCP Server — Environment Variables
# Copy this file to .env and fill in your values.

# Vision model API endpoint (OpenAI-compatible /chat/completions)
MIMO_VISION_API_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# API key for the vision model. This is not the main reasoning model key unless
# you intentionally use the same provider/key for both.
MIMO_VISION_API_KEY=your_api_key_here

# Model name — change this to switch to a different vision model
# Examples: mimo-v2.5, gpt-4o, claude-sonnet-4-6, Qwen2.5-VL-72B
MIMO_VISION_MODEL=mimo-v2.5

# Request timeout in seconds
MIMO_VISION_TIMEOUT=120
